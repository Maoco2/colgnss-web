# App
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=colgnss_user
DB_PASSWORD=colgnss_pass
DB_DATABASE=colgnss_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# Firebase
FIREBASE_PROJECT_ID=colgnss
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@colgnss.iam.gserviceaccount.com

# CORS
CORS_ORIGINS=http://localhost:3000,https://colgnss.vercel.app

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Premium
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
PREMIUM_PRICE_ID=price_placeholder
